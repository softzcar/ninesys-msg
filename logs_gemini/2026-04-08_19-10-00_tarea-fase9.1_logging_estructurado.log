    - `node -e "require('./src/lib/logger'); require('./src/middleware/requestLogger'); require('./websocket'); require('./src/services/waManager'); require('./src/services/aiService'); require('./src/services/baileysAuthState'); require('./controllers/whatsappController'); require('./controllers/authController'); require('./middleware/authenticateToken'); require('./routes/index'); console.log('OK');"` → OK
