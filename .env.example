JWT_SECRET=
API_URL=https://api.nineteengreen.com
APP_URL=
PORT=3000

# Token compartido con ninesys-api para resolver credenciales de tenants
# vía GET {API_URL}/internal/db-credentials/{id_empresa}
MSG_SERVICE_INTERNAL_TOKEN=

# IA (Fase 8). Gemini es el proveedor por defecto. Reutilizar la misma
# GEMINI_API_KEY que usa el chat con IA del frontend (ninesys-api).
GEMINI_API_KEY=
AI_DEFAULT_PROVIDER=gemini
AI_DEFAULT_MODEL=gemini-2.5-flash

# Anthropic queda como proveedor pluggable opcional (no cableado en Fase 8).
ANTHROPIC_API_KEY=

# STT — transcripción de notas de voz con OpenAI Whisper (migración 009).
# Si OPENAI_API_KEY queda vacía, sttService.transcribe lanza error y la nota
# de voz pasa por el fallback normal (sin transcript). El precio vigente está
# hardcoded en src/services/sttService.js (WHISPER_USD_PER_MINUTE).
OPENAI_API_KEY=
# OPENAI_WHISPER_MODEL=whisper-1
# WHISPER_TIMEOUT_MS=60000

# Logging estructurado (Fase 9.1). En desarrollo dejar NODE_ENV vacío para
# usar pino-pretty (output coloreado). En producción NODE_ENV=production
# emite JSON puro a stdout (PM2/journald lo capturan).
# LOG_LEVEL: trace|debug|info|warn|error|fatal (default: debug en dev, info en prod)
LOG_LEVEL=info
# NODE_ENV=production
