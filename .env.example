JWT_SECRET=
API_URL=https://api.nineteengreen.com
APP_URL=
PORT=3000

# Token compartido con ninesys-api para resolver credenciales de tenants
# vía GET {API_URL}/internal/db-credentials/{id_empresa}
MSG_SERVICE_INTERNAL_TOKEN=

# IA (Fase 8). Gemini es el proveedor por defecto. Reutilizar la misma
# GEMINI_API_KEY que usa el chat con IA del frontend (ninesys-api).
GEMINI_API_KEY=
AI_DEFAULT_PROVIDER=gemini
AI_DEFAULT_MODEL=gemini-2.5-flash

# Anthropic queda como proveedor pluggable opcional (no cableado en Fase 8).
ANTHROPIC_API_KEY=
